export default function SellerDashboardInner() {
  // Check if the user entered via the Booking Dashboard
  const isFromBooking = localStorage.getItem("marketplace_subdomain") !== null;

  const handleReturn = () => {
    localStorage.removeItem("marketplace_seller_id");
    localStorage.removeItem("marketplace_subdomain");
    window.location.href = "http://127.0.0.1:5000/owner/dashboard";
  };

  const handleSignOut = () => {
    // Add your standard logout logic here
    localStorage.removeItem("marketplace_seller_id");
    window.location.reload(); 
  };

  return (
    <div className="p-6">
      <div className="flex justify-between items-center mb-6">
        <h1 className="text-2xl font-bold">Vendor Dashboard</h1>
        
        {isFromBooking ? (
          /* Button for users coming from DOABookPro */
          <button 
            onClick={handleReturn}
            className="bg-neutral-800 text-white px-4 py-2 rounded-lg hover:bg-neutral-900 transition-colors"
          >
            ← Return to Booking Dashboard
          </button>
        ) : (
          /* Standard Sign Out for everyone else */
          <button 
            onClick={handleSignOut}
            className="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition-colors"
          >
            Sign Out
          </button>
        )}
      </div>
      
      {/* Rest of your dashboard content */}
    </div>
  );
}